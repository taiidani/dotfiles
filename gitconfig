[user]
	name = Ryan Nixon
	email = {{email}}
	signingkey = ~/.ssh/id_ed25519.pub
[url "git@github.com:"]
	insteadOf = https://github.com/
[commit]
    gpgsign = true
[pull]
	rebase = false
[gpg]
	format = ssh
[core]
	editor = zed --wait
	excludesFile = ~/.config/git/excludes
[init]
	defaultBranch = main
[column]
    ui = auto
